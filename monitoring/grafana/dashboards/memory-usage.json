{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "CloudKitchen - Memory Usage",
  "uid": "ck-memory-usage",
  "tags": ["cloudkitchen", "memory"],
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "query": "cloudkitchen",
        "current": { "text": "cloudkitchen", "value": "cloudkitchen" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Working set memory by pod",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(container_memory_working_set_bytes{namespace=\"$namespace\", container!=\"\", container!=\"POD\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory usage vs limits (by pod)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(container_memory_working_set_bytes{namespace=\"$namespace\", container!=\"\", container!=\"POD\"}) by (pod)",
          "legendFormat": "usage {{pod}}"
        },
        {
          "refId": "B",
          "expr": "sum(kube_pod_container_resource_limits{namespace=\"$namespace\", resource=\"memory\"}) by (pod)",
          "legendFormat": "limit {{pod}}"
        }
      ]
    }
  ]
}
