{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "CloudKitchen - Pod Health / Up",
  "uid": "ck-pod-health",
  "tags": ["cloudkitchen", "health"],
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "query": "cloudkitchen",
        "current": { "text": "cloudkitchen", "value": "cloudkitchen" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(up{namespace=\"$namespace\"})", "legendFormat": "up" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Targets down",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sum(up{namespace=\"$namespace\"} == 0)", "legendFormat": "down" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "up by service (1 = healthy)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "up{namespace=\"$namespace\"}", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Container restarts (rate over 1h)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[1h])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pods not ready",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_pod_status_ready{namespace=\"$namespace\", condition=\"false\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
