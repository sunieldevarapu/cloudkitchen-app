{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "CloudKitchen - HTTP Request Rate",
  "uid": "ck-http-request-rate",
  "tags": ["cloudkitchen", "http"],
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "query": "cloudkitchen",
        "current": { "text": "cloudkitchen", "value": "cloudkitchen" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Total request rate (req/s)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by service",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request rate by method + status code",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[5m])) by (method, code)",
          "legendFormat": "{{method}} {{code}}"
        }
      ]
    }
  ]
}
