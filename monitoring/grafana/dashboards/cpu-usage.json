{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "CloudKitchen - CPU Usage",
  "uid": "ck-cpu-usage",
  "tags": ["cloudkitchen", "cpu"],
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "query": "cloudkitchen",
        "current": { "text": "cloudkitchen", "value": "cloudkitchen" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU usage by pod (cores)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", container!=\"\", container!=\"POD\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU usage vs requests (by pod)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", container!=\"\", container!=\"POD\"}[5m])) by (pod)",
          "legendFormat": "usage {{pod}}"
        },
        {
          "refId": "B",
          "expr": "sum(kube_pod_container_resource_requests{namespace=\"$namespace\", resource=\"cpu\"}) by (pod)",
          "legendFormat": "request {{pod}}"
        }
      ]
    }
  ]
}
