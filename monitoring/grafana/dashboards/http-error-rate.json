{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "CloudKitchen - HTTP Error Rate (5xx)",
  "uid": "ck-http-error-rate",
  "tags": ["cloudkitchen", "http", "errors"],
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "query": "cloudkitchen",
        "current": { "text": "cloudkitchen", "value": "cloudkitchen" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Overall 5xx error ratio (%)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_requests_total{namespace=\"$namespace\", code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{namespace=\"$namespace\"}[5m])), 1))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "5xx error rate by service (req/s)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", code=~\"5..\"}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error ratio by service (% 5xx of all requests)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_requests_total{namespace=\"$namespace\", code=~\"5..\"}[5m])) by (service) / clamp_min(sum(rate(http_requests_total{namespace=\"$namespace\"}[5m])) by (service), 1))",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
